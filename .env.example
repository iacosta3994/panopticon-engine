# Panopticon Engine - Simplified Configuration
# 3 required variables for Supabase deployment

# ====================
# REQUIRED (3 variables)
# ====================

# Supabase Database (Get from: https://supabase.com → Your Project → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT Secret (Generate with: openssl rand -base64 32)
JWT_SECRET=your-random-secret-key-here

# ====================
# OPTIONAL (Add only if needed)
# ====================

# Email Alerts (Optional - Leave blank to disable)
SMTP_USER=
SMTP_PASSWORD=

# Telegram Alerts (Optional - Leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack Alerts (Optional - Leave blank to disable)
SLACK_WEBHOOK_URL=

# Advanced Configuration (Optional - Uses smart defaults)
NODE_ENV=production
PORT=3001
SCAN_INTERVAL_MS=60000
ANOMALY_DETECTION_ENABLED=true
