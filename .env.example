# Panopticon Engine Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Database Configuration (optional, if not using Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/panopticon_engine

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring Configuration
SCAN_INTERVAL_MS=60000
ANOMALY_DETECTION_ENABLED=true
ANOMALY_THRESHOLD_SIGMA=3

# Pattern Analysis
PATTERN_ANALYSIS_INTERVAL=300000
MIN_PATTERN_CONFIDENCE=0.7
MIN_PATTERN_OCCURRENCES=3

# Notification Configuration
NOTIFICATION_ENABLED=true
SLACK_WEBHOOK_URL=
EMAIL_SERVICE_API_KEY=

# Email Configuration
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=panopticon@example.com

# Telegram Configuration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Notion Integration
NOTION_ENABLED=false
NOTION_API_KEY=secret_your_notion_integration_key
NOTION_DATABASE_ID=your-database-id
NOTION_PAGE_ID=your-page-id

# Atlas Integration
ATLAS_ENABLED=false
ATLAS_DB_CONNECTION=postgresql://atlas:password@localhost:5432/atlas_db
ATLAS_NOTIFICATION_ENDPOINT=http://localhost:4000/api/notifications
ATLAS_API_KEY=your-atlas-api-key

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3002

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/panopticon.log

# Cleanup Configuration
RETENTION_DAYS=90
CLEANUP_INTERVAL=86400000

# Feature Flags
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_RELATIONSHIP_MAPPING=true
ENABLE_TEMPORAL_FORECASTING=true
ENABLE_REALTIME_UPDATES=true
ENABLE_DASHBOARD=true

# Dashboard Configuration
DASHBOARD_REFRESH_INTERVAL=5000
MAX_DASHBOARD_ITEMS=100
