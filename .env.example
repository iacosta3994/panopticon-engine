# Panopticon Engine - Minimal Configuration
# Only 1 variable required!

# JWT Secret (REQUIRED) - Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-secret-key

# That's it! Everything else has smart defaults.
# The system will:
# - Use embedded SQLite database (auto-created)
# - Run migrations automatically on first start
# - Use sensible defaults for all features
# - Work completely offline

# ============================================
# OPTIONAL: Add these ONLY if you need them
# ============================================

# Email Alerts (Optional - Leave blank to disable)
SMTP_USER=
SMTP_PASSWORD=

# Telegram Alerts (Optional - Leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
